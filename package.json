{
  "name": "api-fastify-passport-vitest-prisma",
  "version": "1.0.0",
  "description": "A kind of boilerplate for a fastify REST API with passport, vitest and prisma",
  "type": "module",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "npm run build:ts && fastify start -l info dist/app.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "clear": "rm -rf node_modules dist coverage",
    "clean": "npm run clear && npm ci"
  },
  "keywords": [],
  "author": "Bersez Nathan",
  "license": "Unlicense",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/passport": "^3.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@scalar/fastify-api-reference": "^1.51.0",
    "@t3-oss/env-core": "^0.13.11",
    "argon2": "^0.44.0",
    "fastify": "^5.8.4",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "otplib": "^13.4.0",
    "passport-amazon": "^1.0.0",
    "passport-apple": "^2.0.2",
    "passport-discord": "^0.1.4",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "passport-paypal-openidconnect": "^0.1.1",
    "passport-twitter": "^1.0.4",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/passport": "^1.0.17",
    "@types/passport-apple": "^2.0.3",
    "@types/passport-discord": "^0.1.15",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-linkedin-oauth2": "^1.5.6",
    "@types/passport-microsoft": "^2.1.1",
    "@types/passport-oauth2": "^1.8.0",
    "@types/passport-openidconnect": "^0.1.3",
    "@types/passport-twitter": "^1.0.40",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "fastify-tsconfig": "^3.0.0",
    "husky": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.1"
  }
}
